{
  "name": "cabinet-management-pwa",
  "version": "1.0.0",
  "description": "Angular PWA mobile-first for managing patients, appointments, sessions, payments, expenses and dashboard analytics for a small therapy practice.",
  "scripts": {
    "start": "ng serve",
